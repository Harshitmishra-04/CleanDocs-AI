# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model id on OpenRouter (default: openai/gpt-4o-mini)
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Max completion tokens per request (default 4096). Lower if OpenRouter returns 402
# (insufficient credits for reserved output budget). Example: MAX_OUTPUT_TOKENS=2048
# MAX_OUTPUT_TOKENS=4096

# Optional: shown on OpenRouter rankings
# OPENROUTER_HTTP_REFERER=http://127.0.0.1:5000
# OPENROUTER_APP_TITLE=GPT-Cleaner

# Legacy: OpenAI key also accepted if OPENROUTER_API_KEY is unset
# OPENAI_API_KEY=
